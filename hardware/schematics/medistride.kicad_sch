  ;; ============================================================
  ;; U1 - XIAO ESP32-S3 Microcontroller
  ;; ============================================================
  ;; Pinout (left side, top to bottom):
  ;;   1: D0/A0 (GPIO1)   - FSR1 (Talon centre)
  ;;   2: D1/A1 (GPIO2)   - FSR2 (Talon latéral)
  ;;   3: D2/A2 (GPIO3)   - FSR3 (Arche)
  ;;   4: D3/A3 (GPIO4)   - FSR4 (1er métatarse)
  ;;   5: D4/A4 (GPIO5)   - FSR5 (3e-4e métatarse)
  ;;   6: D5/A5 (GPIO6)   - FSR6 (Gros orteil)
  ;;   7: D6/SDA (GPIO43) - I2C SDA (réservé IMU)
  ;; Pinout (right side, top to bottom):
  ;;   14: 5V              - USB power
  ;;   13: GND              - Ground
  ;;   12: 3V3              - 3.3V output
  ;;   11: D10/MOSI (GPIO9) - Libre
  ;;   10: D9/MISO (GPIO8)  - Libre
  ;;   9:  D8/SCK (GPIO7)   - Libre
  ;;   8:  D7/SCL (GPIO44)  - I2C SCL (réservé IMU)
  ;; Battery pads: BAT+ / BAT-

  (symbol
    (lib_id "MCU_Module:XIAO_ESP32-S3")
    (at 88.9 88.9 0)
    (unit 1)
    (exclude_from_sim no)
    (in_bom yes)
    (on_board yes)
    (uuid "u1-esp32s3")
    (property "Reference" "U1" (at 88.9 60.96 0) (effects (font (size 1.524 1.524))))
    (property "Value" "XIAO_ESP32-S3" (at 88.9 63.5 0) (effects (font (size 1.524 1.524))))
    (property "Footprint" "" (at 88.9 88.9 0) (effects (font (size 1.27 1.27)) hide))
    (property "Datasheet" "https://wiki.seeedstudio.com/xiao_esp32s3_getting_started/" (at 88.9 88.9 0) (effects (font (size 1.27 1.27)) hide))
    (pin "1" (uuid "u1-pin1"))
    (pin "2" (uuid "u1-pin2"))
    (pin "3" (uuid "u1-pin3"))
    (pin "4" (uuid "u1-pin4"))
    (pin "5" (uuid "u1-pin5"))
    (pin "6" (uuid "u1-pin6"))
    (pin "7" (uuid "u1-pin7"))
    (pin "8" (uuid "u1-pin8"))
    (pin "9" (uuid "u1-pin9"))
    (pin "10" (uuid "u1-pin10"))
    (pin "11" (uuid "u1-pin11"))
    (pin "12" (uuid "u1-pin12"))
    (pin "13" (uuid "u1-pin13"))
    (pin "14" (uuid "u1-pin14"))
    (pin "BAT+" (uuid "u1-bat+"))
    (pin "BAT-" (uuid "u1-bat-"))
  )


  ;; ============================================================
  ;; U2 - MPU-6050 IMU 6 axes (OPTIONNEL)
  ;; Accéléromètre 3 axes + Gyroscope 3 axes
  ;; Connecté en I2C : SDA (GPIO43), SCL (GPIO44)
  ;; Adresse I2C : 0x68 (AD0 → GND)
  ;; ============================================================

  (symbol
    (lib_id "Sensor_Motion:MPU-6050")
    (at 190.5 195.58 0)
    (unit 1)
    (exclude_from_sim no)
    (in_bom yes)
    (on_board yes)
    (dnp yes)
    (uuid "u2-mpu6050")
    (property "Reference" "U2" (at 190.5 180.34 0) (effects (font (size 1.524 1.524))))
    (property "Value" "MPU-6050 [OPTIONNEL]" (at 190.5 182.88 0) (effects (font (size 1.27 1.27))))
    (property "Footprint" "" (at 190.5 195.58 0) (effects (font (size 1.27 1.27)) hide))
    (property "Datasheet" "https://invensense.tdk.com/wp-content/uploads/2015/02/MPU-6000-Datasheet1.pdf" (at 190.5 195.58 0) (effects (font (size 1.27 1.27)) hide))
    (property "Description" "IMU 6 axes (optionnel) - Orientation du pied, cadence, phases du pas" (at 190.5 195.58 0) (effects (font (size 1.27 1.27)) hide))
    (pin "VCC" (uuid "u2-vcc"))
    (pin "GND" (uuid "u2-gnd"))
    (pin "SDA" (uuid "u2-sda"))
    (pin "SCL" (uuid "u2-scl"))
    (pin "AD0" (uuid "u2-ad0"))
    (pin "INT" (uuid "u2-int"))
  )


  ;; --- IMU I2C wires ---
  ;; SDA : GPIO43 (D6) → R7 pull-up → MPU-6050 SDA
  (wire (pts (xy 63.5 104.14) (xy 170.18 190.5)))
  (wire (pts (xy 170.18 190.5) (xy 190.5 195.58)))
  ;; SCL : GPIO44 (D7) → R8 pull-up → MPU-6050 SCL
  (wire (pts (xy 114.3 104.14) (xy 210.82 190.5)))
  (wire (pts (xy 210.82 190.5) (xy 190.5 198.12)))
  ;; MPU-6050 VCC → +3V3
  (wire (pts (xy 190.5 187.96) (xy 190.5 185.42)))
  ;; MPU-6050 GND → GND
  (wire (pts (xy 190.5 205.74) (xy 190.5 210.82)))
  ;; MPU-6050 AD0 → GND (adresse 0x68)
  (wire (pts (xy 198.12 205.74) (xy 198.12 210.82)))

  (net_label "+3V3" (at 190.5 185.42 0) (effects (font (size 1.27 1.27))))
  (net_label "GND" (at 190.5 210.82 0) (effects (font (size 1.27 1.27))))

  (text "MPU-6050 (OPTIONNEL)\nIMU 6 axes : accéléromètre + gyroscope\nConnexion I2C (adresse 0x68)\n\nApporte :\n- Détection des phases du cycle de marche\n- Mesure de la cadence (pas/minute)\n- Orientation dynamique du pied\n\nLa plupart des modules incluent\nles pull-ups I2C et le découplage.\nR7, R8 et C3 sont alors inutiles.\n\nAlternative premium : BNO055\n(9 axes + fusion intégrée, ~25-30 USD)"
    (at 240 195.58 0)
    (effects (font (size 1.524 1.524)))
  )

